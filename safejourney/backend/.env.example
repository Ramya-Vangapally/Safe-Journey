# Copy this file to .env and fill values locally. Never commit real secrets.

# Database (optional). If omitted, SQLite file safejourney.db is used.
DATABASE_URL=

# Twilio (optional, needed only for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional integrations used by SOS service
TWILIO_PHONE=
FAST2SMS_API_KEY=
SOS_WEBHOOK_URL=
